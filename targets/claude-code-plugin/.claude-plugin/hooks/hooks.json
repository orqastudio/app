{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/pre-tool-use.js",
						"timeout": 10
					}
				]
			},
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/pre-tool-use.js",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/post-tool-use.js",
						"timeout": 10
					}
				]
			},
			{
				"matcher": "TaskUpdate",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/post-tool-use.js",
						"timeout": 10
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/user-prompt-submit.js",
						"timeout": 10
					}
				]
			}
		],
		"SessionStart": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/session-start.js",
						"timeout": 15
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/stop.js",
						"timeout": 10
					}
				]
			}
		],
		"PreCompact": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/pre-compact.js",
						"timeout": 10
					}
				]
			}
		],
		"SubagentStop": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/subagent-stop.js",
						"timeout": 15
					}
				]
			}
		],
		"TeammateIdle": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/teammate-idle.js",
						"timeout": 10
					}
				]
			}
		],
		"TaskCompleted": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "node ${CLAUDE_PLUGIN_ROOT}/dist/scripts/task-completed.js",
						"timeout": 10
					}
				]
			}
		]
	}
}
