{
  "name": "@orqastudio/plugin-agile-discovery",
  "version": "0.1.4-dev",
  "description": "Discovery-stage artifact types — vision, personas, pillars, pivots, ideas, research, and strategic decisions. Fills the discovery stage slot of agile-methodology.",
  "purpose": ["workflow"],
  "stage_slot": "discovery",
  "affects_schema": true,
  "affects_enforcement": false,
  "category": "discovery",
  "uninstallable": false,
  "provides": {
    "schemas": [
      {
        "key": "vision",
        "title": "Vision",
        "idPrefix": "VISION",
        "installPath": ".orqa/discovery/vision"
      },
      {
        "key": "pillar",
        "title": "Pillar",
        "idPrefix": "PILLAR",
        "installPath": ".orqa/discovery/pillars"
      },
      {
        "key": "persona",
        "title": "Persona",
        "idPrefix": "PERSONA",
        "installPath": ".orqa/discovery/personas"
      },
      {
        "key": "pivot",
        "title": "Pivot",
        "idPrefix": "PIVOT",
        "installPath": ".orqa/discovery/pivots"
      },
      {
        "key": "discovery-idea",
        "title": "Discovery Idea",
        "idPrefix": "DISC-IDEA",
        "installPath": ".orqa/discovery/ideas"
      },
      {
        "key": "discovery-research",
        "title": "Discovery Research",
        "idPrefix": "DISC-RES",
        "installPath": ".orqa/discovery/research"
      },
      {
        "key": "discovery-decision",
        "title": "Discovery Decision",
        "idPrefix": "DISC-AD",
        "installPath": ".orqa/discovery/decisions"
      }
    ],
    "workflows": [
      {
        "artifact_type": "vision",
        "path": "workflows/vision.workflow.yaml"
      },
      {
        "artifact_type": "pillar",
        "path": "workflows/pillar.workflow.yaml"
      },
      {
        "artifact_type": "persona",
        "path": "workflows/persona.workflow.yaml"
      },
      {
        "artifact_type": "pivot",
        "path": "workflows/pivot.workflow.yaml"
      },
      {
        "artifact_type": "discovery-idea",
        "path": "workflows/discovery-idea.workflow.yaml"
      },
      {
        "artifact_type": "discovery-research",
        "path": "workflows/discovery-research.workflow.yaml"
      },
      {
        "artifact_type": "discovery-decision",
        "path": "workflows/discovery-decision.workflow.yaml"
      },
      {
        "artifact_type": "epic",
        "path": "workflows/discovery.contribution.workflow.yaml",
        "contribution": true,
        "description": "Discovery stage contribution point — outputs feed planning inputs"
      }
    ],
    "knowledge": [],
    "rules": [],
    "roles": [],
    "views": [],
    "enforcement_mechanisms": []
  }
}
