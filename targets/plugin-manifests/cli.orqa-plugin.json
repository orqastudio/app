				"entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
				"args": ["enforce"],
				"category": "integrity"
			},
			{
				"key": "orqa-graph-stats",
				"label": "Graph Statistics",
				"icon": "bar-chart-3",
				"runtime": "node",
				"entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
				"args": ["graph", "--stats", "--json"],
				"category": "custom"
			},
			{
				"key": "orqa-version-check",
				"label": "Version Drift Check",
				"icon": "git-compare",
				"runtime": "node",
				"entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
				"args": ["version", "check"],
				"category": "integrity"
			},
			{
				"key": "orqa-repo-license",
				"label": "License Audit",
				"icon": "scale",
				"runtime": "node",
				"entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
				"args": ["repo", "license"],
				"category": "integrity"
			},
			{
				"key": "orqa-repo-readme",
				"label": "README Audit",
				"icon": "file-text",
				"runtime": "node",
				"entrypoint": "node_modules/@orqastudio/cli/dist/cli.js",
				"args": ["repo", "readme"],
				"category": "integrity"
			}
		],
		"hooks": [
			{
				"event": "PreCommit",
				"command": "cd cli && npx tsc && cd .. && orqa verify",
				"description": "Rebuild CLI then run all audits before every commit"
			},
			{
				"event": "SessionStart",
				"command": "orqa version check",
				"description": "Check for version drift at session start"
			}
		],
