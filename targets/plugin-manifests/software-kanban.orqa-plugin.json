{
  "name": "@orqastudio/plugin-software-kanban",
  "version": "0.1.4-dev",
  "description": "Software development lifecycle — delivery planning with milestones, epics and tasks, roadmap views, and delivery pipeline widgets. Fills the implementation stage slot of agile-methodology.",
  "purpose": ["workflow"],
  "stage_slot": "implementation",
  "affects_schema": true,
  "affects_enforcement": false,
  "category": "delivery",
  "uninstallable": false,
  "provides": {
    "schemas": [
      {
        "key": "milestone",
        "title": "Milestone",
        "idPrefix": "MS",
        "installPath": ".orqa/implementation/milestones"
      },
      {
        "key": "epic",
        "title": "Epic",
        "idPrefix": "EPIC",
        "installPath": ".orqa/implementation/epics"
      },
      {
        "key": "task",
        "title": "Task",
        "idPrefix": "TASK",
        "installPath": ".orqa/implementation/tasks"
      }
    ],
    "workflows": [
      {
        "artifact_type": "milestone",
        "path": "workflows/milestone.workflow.yaml"
      },
      {
        "artifact_type": "epic",
        "path": "workflows/epic.workflow.yaml"
      },
      {
        "artifact_type": "task",
        "path": "workflows/task.workflow.yaml"
      }
    ],
    "knowledge": [],
    "rules": [],
    "roles": [],
    "views": [
      {
        "key": "roadmap",
        "title": "Roadmap",
        "icon": "kanban",
        "description": "Kanban/roadmap view for epics and milestones"
      }
    ],
    "enforcement_mechanisms": []
  }
}
