{
  "name": "@orqastudio/plugin-svelte",
  "version": "0.1.0-dev",
  "displayName": "Svelte Development",
  "description": "Svelte development infrastructure — extends the TypeScript plugin with Svelte parser, svelte-check, Vitest config, and Svelte ESLint rules.",
  "extends": ["@orqastudio/plugin-typescript"],
  "configExtensions": {
    "tsconfig": {
      "compilerOptions": {
        "verbatimModuleSyntax": true
      }
    },
    "eslint": {
      "import": "@orqastudio/plugin-svelte/eslint",
      "export": "svelte"
    }
  },
  "provides": {
    "agents": [
      { "key": "svelte-standards", "path": "agents/svelte-standards.md" },
      { "key": "svelte-specialist", "path": "agents/svelte-specialist.md" }
    ],
    "schemas": [],
    "views": [],
    "widgets": [],
    "lspServers": {
      "svelte": {
        "command": "svelteserver",
        "args": ["--stdio"],
        "extensionToLanguage": {
          ".svelte": "svelte"
        }
      }
    },
    "relationships": [],
    "knowledge": [
      { "key": "svelte-patterns", "id": "KNOW-SVE-89d35141", "label": "Svelte 5 Patterns" },
      { "key": "eslint-config-management", "id": "KNOW-SVE-88f32b6a", "label": "ESLint Config Management" },
      { "key": "testing-patterns", "id": "KNOW-SVE-fd2b84c4", "label": "Testing Patterns" },
      { "key": "svelte-installation", "id": "KNOW-SVE-90dd73ab", "label": "Svelte Plugin Installation" },
      { "key": "svelte5-best-practices", "id": "KNOW-1c708b68", "label": "Svelte 5 Best Practices" },
      { "key": "svelte5-runes", "id": "KNOW-SVE-005", "label": "Svelte 5 Runes Reference" },
      { "key": "svelte5-snippets", "id": "KNOW-SVE-006", "label": "Svelte 5 Snippets Reference" },
      { "key": "svelte5-events", "id": "KNOW-SVE-007", "label": "Svelte 5 Events Reference" },
      { "key": "svelte5-typescript", "id": "KNOW-SVE-008", "label": "Svelte 5 TypeScript Reference" },
      { "key": "svelte5-migration", "id": "KNOW-SVE-009", "label": "Svelte 4→5 Migration Reference" },
      { "key": "svelte5-sveltekit", "id": "KNOW-SVE-010", "label": "SvelteKit Patterns Reference" },
      { "key": "svelte5-performance", "id": "KNOW-SVE-011", "label": "Svelte 5 Performance Reference" },
      { "key": "tailwind-design-system", "id": "KNOW-SVE-012", "label": "Tailwind Design System" }
    ],
    "tools": {
      "eslint": {
        "command": "npx eslint",
        "configFile": ".eslintrc.json",
        "configFormat": "json"
      },
      "svelte-check": {
        "command": "npx svelte-check",
        "configFile": null,
        "configFormat": "cli-args"
      },
      "vitest": {
        "command": "npx vitest run",
        "configFile": "vitest.config.ts",
        "configFormat": "ts"
      }
    },
    "dependencies": {
      "devDependencies": {
        "eslint": "^9.0.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint-plugin-svelte": "^3.0.0",
        "svelte-check": "^4.0.0",
        "vitest": "^3.0.0",
        "@testing-library/svelte": "^5.0.0",
        "typescript": "^5.9.0"
      }
    },
    "cliTools": [],
    "hooks": [],
    "decision_tree": {
      "branches": [
        {
          "mode": "implementation",
          "domain": "svelte-frontend",
          "description": "Building Svelte 5 UI — components, stores, pages, runes-based reactivity",
          "search_context": "svelte5 runes, $state, $derived, component purity, shadcn-svelte, tailwind"
        }
      ]
    }
  }
}
