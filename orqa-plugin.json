{
  "name": "@orqastudio/plugin-rust",
  "displayName": "Rust",
  "version": "0.1.0-dev",
  "description": "Base Rust development infrastructure — clippy, rustfmt, cargo test configuration and coding standards enforcement.",
  "category": "coding-standards",
  "provides": {
    "agents": [
      { "key": "rust-standards", "path": "agents/rust-standards.md" },
      { "key": "rust-specialist", "path": "agents/rust-specialist.md" }
    ],
    "lspServers": {
      "rust": {
        "command": "rust-analyzer",
        "extensionToLanguage": {
          ".rs": "rust"
        }
      }
    },
    "knowledge": [
      { "key": "clippy-config-management", "id": "KNOW-5efa83a5", "label": "Clippy Config Management" },
      { "key": "rust-testing-patterns", "id": "KNOW-214b7cdc", "label": "Rust Testing Patterns" },
      { "key": "rust-installation", "id": "KNOW-2a72f929", "label": "Rust Plugin Installation" },
      { "key": "rust-async-patterns", "id": "KNOW-c323ec5f", "label": "Rust Async Patterns" }
    ],
    "tools": {
      "clippy": {
        "command": "cargo clippy",
        "configFile": "clippy.toml",
        "configFormat": "toml"
      },
      "rustfmt": {
        "command": "cargo fmt --check",
        "configFile": ".rustfmt.toml",
        "configFormat": "toml"
      },
      "cargo-test": {
        "command": "cargo test",
        "configFile": null,
        "configFormat": "cli-args"
      }
    },
    "dependencies": {
      "rustToolchain": "stable"
    },
    "decision_tree": {
      "branches": [
        {
          "mode": "implementation",
          "domain": "rust-backend",
          "description": "Implementing Rust code — Tauri commands, domain logic, repositories, async patterns",
          "search_context": "rust async, tauri command, thiserror, repository pattern, domain service"
        }
      ]
    }
  }
}
