{
  "name": "@orqastudio/plugin-rust",
  "displayName": "Rust",
  "version": "0.1.0-dev",
  "description": "Base Rust development infrastructure — clippy, rustfmt, cargo test configuration and coding standards enforcement.",
  "category": "coding-standards",
  "provides": {
    "lspServers": {
      "rust": {
        "command": "rust-analyzer",
        "extensionToLanguage": {
          ".rs": "rust"
        }
      }
    },
    "skills": [
      { "key": "clippy-config-management", "id": "SKILL-RST-5efa83a5", "label": "Clippy Config Management" },
      { "key": "rust-testing-patterns", "id": "SKILL-RST-214b7cdc", "label": "Rust Testing Patterns" },
      { "key": "rust-installation", "id": "SKILL-RST-2a72f929", "label": "Rust Plugin Installation" },
      { "key": "rust-async-patterns", "id": "SKILL-c323ec5f", "label": "Rust Async Patterns" }
    ],
    "tools": {
      "clippy": {
        "command": "cargo clippy",
        "configFile": "clippy.toml",
        "configFormat": "toml"
      },
      "rustfmt": {
        "command": "cargo fmt --check",
        "configFile": ".rustfmt.toml",
        "configFormat": "toml"
      },
      "cargo-test": {
        "command": "cargo test",
        "configFile": null,
        "configFormat": "cli-args"
      }
    },
    "dependencies": {
      "rustToolchain": "stable"
    }
  }
}
