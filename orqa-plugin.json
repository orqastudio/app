    "cliTools": [],
    "hooks": [],
    "behavioral_rules": [
      "When an epic is scoped: sync session state steps and task list with the epic's tasks — work against the epic's defined tasks, not ad-hoc."
    ],
    "session_reminders": [
      "Session state MUST include the scoped epic (EPIC-XXXXXXXX) so the stop hook can check completion."
    ],
    "decision_tree": {
      "branches": [
        {
          "mode": "implementation",
          "domain": "delivery",
          "description": "Working on epics, tasks, milestones — delivery planning and tracking",
          "search_context": "delivery planning, epic scoping, task breakdown, milestone tracking"
        },
        {
          "mode": "implementation",
          "domain": "bug-tracking",
          "description": "Reporting and fixing bugs against delivery artifacts",
          "search_context": "bug triage, bug reporting, fix verification"
        }
      ]
    }
  },
  "defaultNavigation": [
