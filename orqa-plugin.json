{
  "name": "@orqastudio/plugin-rust",
  "displayName": "Rust",
  "version": "0.1.0-dev",
  "description": "Base Rust development infrastructure — clippy, rustfmt, cargo test configuration and coding standards enforcement.",
  "category": "coding-standards",
  "provides": {
    "skills": [
      {
        "key": "clippy-config-management",
        "id": "SKILL-RST-001",
        "label": "Clippy Config Management"
      },
      {
        "key": "rust-testing-patterns",
        "id": "SKILL-RST-002",
        "label": "Rust Testing Patterns"
      },
      {
        "key": "rust-installation",
        "id": "SKILL-RST-003",
        "label": "Rust Plugin Installation"
      }
    ],
    "tools": {
      "clippy": {
        "command": "cargo clippy",
        "configFile": "clippy.toml",
        "configFormat": "toml"
      },
      "rustfmt": {
        "command": "cargo fmt --check",
        "configFile": ".rustfmt.toml",
        "configFormat": "toml"
      },
      "cargo-test": {
        "command": "cargo test",
        "configFile": null,
        "configFormat": "cli-args"
      }
    },
    "dependencies": {
      "rustToolchain": "stable"
    }
  }
}
