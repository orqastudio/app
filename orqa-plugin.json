{
  "name": "@orqastudio/plugin-software-project",
  "version": "0.1.0-dev",
  "displayName": "Software Project",
  "description": "Software development lifecycle — delivery planning with milestones, epics and tasks, research discovery, roadmap views, and delivery pipeline widgets.",
  "provides": {
    "schemas": [
      {
        "key": "milestone",
        "label": "Milestone",
        "plural": "Milestones",
        "icon": "flag",
        "defaultPath": ".orqa/delivery/milestones",
        "idPrefix": "MS",
        "frontmatter": {
          "required": ["id", "type", "status"],
          "optional": ["name", "description", "gate", "priority", "target_date", "relationships"]
        },
        "statusTransitions": {
          "captured": ["exploring", "ready", "prioritised"],
          "exploring": ["ready", "prioritised", "hold"],
          "ready": ["prioritised", "active", "review"],
          "prioritised": ["active", "ready"],
          "active": ["hold", "blocked", "review"],
          "hold": ["active", "ready"],
          "blocked": ["active", "ready"],
          "review": ["completed", "active"],
          "completed": ["surpassed"]
        }
      },
      {
        "key": "epic",
        "label": "Epic",
        "plural": "Epics",
        "icon": "layers",
        "defaultPath": ".orqa/delivery/epics",
        "idPrefix": "EPIC",
        "frontmatter": {
          "required": ["id", "type", "status"],
          "optional": ["name", "description", "priority", "relationships"]
        },
        "statusTransitions": {
          "captured": ["exploring", "ready", "prioritised"],
          "exploring": ["ready", "prioritised", "hold"],
          "ready": ["prioritised", "active", "review"],
          "prioritised": ["active", "ready"],
          "active": ["hold", "blocked", "review"],
          "hold": ["active", "ready"],
          "blocked": ["active", "ready"],
          "review": ["completed", "active"],
          "completed": ["surpassed"]
        }
      },
      {
        "key": "task",
        "label": "Task",
        "plural": "Tasks",
        "icon": "check-square",
        "defaultPath": ".orqa/delivery/tasks",
        "idPrefix": "TASK",
        "frontmatter": {
          "required": ["id", "type", "status"],
          "optional": ["name", "description", "priority", "assignee", "relationships"]
        },
        "statusTransitions": {
          "captured": ["ready", "prioritised"],
          "ready": ["prioritised", "active"],
          "prioritised": ["active", "ready"],
          "active": ["hold", "blocked", "review"],
          "hold": ["active", "ready"],
          "blocked": ["active", "ready"],
          "review": ["completed", "active"],
          "completed": ["surpassed"]
        }
      },
      {
        "key": "research",
        "label": "Research",
        "plural": "Research",
        "icon": "flask-conical",
        "defaultPath": ".orqa/discovery/research",
        "idPrefix": "RES",
        "frontmatter": {
          "required": ["id", "type", "status"],
          "optional": ["name", "description", "methodology", "relationships"]
        },
        "statusTransitions": {
          "captured": ["exploring", "active"],
          "exploring": ["active", "hold"],
          "active": ["review", "hold"],
          "hold": ["active", "exploring"],
          "review": ["completed", "active"],
          "completed": ["surpassed", "archived"]
        }
      },
      {
        "key": "wireframe",
        "label": "Wireframe",
        "plural": "Wireframes",
        "icon": "layout",
        "defaultPath": ".orqa/discovery/wireframes",
        "idPrefix": "WF",
        "frontmatter": {
          "required": ["id", "type", "status"],
          "optional": ["name", "description", "relationships"]
        },
        "statusTransitions": {
          "captured": ["exploring", "active"],
          "exploring": ["active", "review"],
          "active": ["review", "hold"],
          "review": ["completed", "active"],
          "completed": ["surpassed", "archived"]
        }
      }
    ],
    "views": [
      { "key": "roadmap", "label": "Roadmap", "icon": "kanban" }
    ],
    "widgets": [
      {
        "key": "pipeline",
        "label": "Delivery Pipeline",
        "icon": "git-branch",
        "defaultPosition": { "row": 0, "col": 0 },
        "defaultSpan": { "rows": 1, "cols": 2 }
      },
      {
        "key": "milestone-context",
        "label": "Milestone Context",
        "icon": "flag",
        "defaultPosition": { "row": 0, "col": 2 },
        "defaultSpan": { "rows": 1, "cols": 1 }
      }
    ],
    "relationships": [
      {
        "key": "depends-on",
        "inverse": "depended-on-by",
        "label": "Depends On",
        "inverseLabel": "Depended On By",
        "from": ["task", "epic"],
        "to": ["task", "epic"],
        "description": "Delivery dependency — this artifact cannot proceed until the target is completed.",
        "semantic": "dependency"
      }
    ],
    "cliTools": [],
    "hooks": []
  },
  "defaultNavigation": [
    {
      "key": "discovery",
      "type": "group",
      "icon": "compass",
      "label": "Discovery",
      "children": [
        { "key": "research", "type": "plugin", "icon": "flask-conical", "pluginSource": "@orqastudio/plugin-software-project" },
        { "key": "wireframes", "type": "plugin", "icon": "layout", "pluginSource": "@orqastudio/plugin-software-project" }
      ]
    },
    {
      "key": "delivery",
      "type": "group",
      "icon": "rocket",
      "label": "Delivery",
      "children": [
        { "key": "roadmap", "type": "plugin", "icon": "kanban", "pluginSource": "@orqastudio/plugin-software-project" },
        { "key": "milestones", "type": "plugin", "icon": "flag", "pluginSource": "@orqastudio/plugin-software-project" },
        { "key": "epics", "type": "plugin", "icon": "layers", "pluginSource": "@orqastudio/plugin-software-project" },
        { "key": "tasks", "type": "plugin", "icon": "check-square", "pluginSource": "@orqastudio/plugin-software-project" }
      ]
    }
  ],
  "delivery": {
    "types": [
      {
        "key": "milestone",
        "label": "Milestone",
        "path": ".orqa/delivery/milestones",
        "parent": null,
        "gate_field": "gate"
      },
      {
        "key": "epic",
        "label": "Epic",
        "path": ".orqa/delivery/epics",
        "parent": { "type": "milestone", "relationship": "delivers" }
      },
      {
        "key": "task",
        "label": "Task",
        "path": ".orqa/delivery/tasks",
        "parent": { "type": "epic", "relationship": "delivers" }
      }
    ]
  },
  "artifactLinks": {
    "displayModes": {
      "MS": "title",
      "EPIC": "title",
      "TASK": "title",
      "RES": "title",
      "WF": "title"
    },
    "colors": {
      "MS": "#38bdf8",
      "EPIC": "#3b82f6",
      "TASK": "#06b6d4",
      "RES": "#6366f1",
      "WF": "#a78bfa"
    }
  },
  "coreRelationships": {
    "_comment": "How plugin artifact types relate to core platform artifacts. Pillars connect to ideas — traceability to pillars is transitive through the graph (idea → epic → task), not direct.",
    "patterns": [
      {
        "from": ["epic", "task"],
        "relationship": "driven-by",
        "to": ["decision"],
        "description": "Work is motivated by architecture decisions."
      },
      {
        "from": ["task"],
        "relationship": "informed-by",
        "to": ["research", "lesson"],
        "description": "Tasks are informed by research findings and lessons learned."
      },
      {
        "from": ["research"],
        "relationship": "informs",
        "to": ["idea", "decision", "epic"],
        "description": "Research findings flow into ideas, decisions, and epics."
      },
      {
        "from": ["wireframe"],
        "relationship": "informs",
        "to": ["epic", "task"],
        "description": "Wireframes inform the work that implements them."
      },
      {
        "from": ["epic"],
        "relationship": "evolves-from",
        "to": ["idea"],
        "description": "Epics evolve from ideas that have been validated."
      }
    ]
  }
}
