  "delivery": {
    "types": [
      {
        "key": "milestone",
        "label": "Milestone",
        "path": ".orqa/delivery/milestones",
        "parent": null,
        "gate_field": "gate"
      },
      {
        "key": "epic",
        "label": "Epic",
        "path": ".orqa/delivery/epics",
        "parent": {
          "type": "milestone",
          "relationship": "fulfils"
        }
      },
      {
        "key": "task",
        "label": "Task",
        "path": ".orqa/delivery/tasks",
        "parent": {
          "type": "epic",
          "relationship": "delivers"
        }
      }
    ]
  },
  "artifactLinks": {
    "displayModes": {
      "MS": "title",
      "EPIC": "title",
      "TASK": "title",
      "RES": "title",
      "WF": "title",
      "BUG": "title"
    },
    "colors": {
      "MS": "#38bdf8",
      "EPIC": "#3b82f6",
      "TASK": "#06b6d4",
      "RES": "#6366f1",
      "WF": "#a78bfa",
      "BUG": "#ef4444"
    }
  },
  "semantics": {
    "hierarchy": {
      "description": "Delivery hierarchy — work rolls up to parent artifacts",
      "keys": [
        "delivers",
        "delivered-by",
        "fulfils",
        "fulfilled-by"
      ]
    },
    "dependency": {
      "description": "Task sequencing — blocked status inferred from unmet dependencies",
      "keys": [
        "depends-on",
        "depended-on-by"
      ]
    },
    "corrective": {
      "description": "Bug tracking — reporting issues and fixing them",
      "keys": [
        "reports",
        "reported-by",
        "fixes",
        "fixed-by",
        "affects",
        "affected-by"
      ]
    },
    "delivery": {
      "description": "Governance-to-delivery bridge — tracing implementation back to decisions",
      "keys": [
        "implements",
        "implemented-by"
      ]
    }
  }
