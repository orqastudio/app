{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/orqastudio/orqastudio-types/blob/main/schemas/orqa-plugin.json",
  "title": "OrqaStudio Plugin Manifest",
  "description": "Schema for orqa-plugin.json — the manifest that defines an OrqaStudio plugin's identity, compatibility, capabilities, and entry points.",
  "type": "object",
  "required": ["name", "version", "description", "compatibility", "provides"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference for editor autocompletion."
    },

    "name": {
      "type": "string",
      "pattern": "^@?[a-z0-9-]+(/[a-z0-9-]+)?$",
      "description": "Package name. Scoped (@org/name) or unscoped (name)."
    },

    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$",
      "description": "Semver version string."
    },

    "displayName": {
      "type": "string",
      "description": "Human-readable name shown in the plugin manager UI."
    },

    "description": {
      "type": "string",
      "description": "Short description of what the plugin does."
    },

    "author": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "email": { "type": "string", "format": "email" }
      }
    },

    "license": {
      "type": "string",
      "description": "SPDX license identifier."
    },

    "compatibility": {
      "type": "object",
      "description": "Minimum versions required for this plugin to function.",
      "required": ["app"],
      "additionalProperties": false,
      "properties": {
        "app": {
          "type": "string",
          "description": "Minimum OrqaStudio app version (semver range)."
        },
        "sdk": {
          "type": "string",
          "description": "Minimum @orqastudio/sdk version (semver range)."
        },
        "types": {
          "type": "string",
          "description": "Minimum @orqastudio/types version (semver range)."
        }
      }
    },

    "provides": {
      "type": "object",
      "description": "Capabilities this plugin registers with the app at runtime.",
      "additionalProperties": false,
      "properties": {
        "artifactTypes": {
          "type": "array",
          "description": "Artifact types this plugin introduces.",
          "items": {
            "type": "object",
            "required": ["key", "label", "icon", "path"],
            "additionalProperties": false,
            "properties": {
              "key": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$",
                "description": "Unique artifact type key (lowercase, hyphenated)."
              },
              "label": {
                "type": "string",
                "description": "Singular display label."
              },
              "plural": {
                "type": "string",
                "description": "Plural display label."
              },
              "icon": {
                "type": "string",
                "description": "Icon key to register (must also appear in provides.icons)."
              },
              "path": {
                "type": "string",
                "description": "Relative path within .orqa/ where artifacts of this type are stored."
              }
            }
          }
        },

        "views": {
          "type": "array",
          "description": "Custom views this plugin adds to the app.",
          "items": {
            "type": "object",
            "required": ["key", "label", "entrypoint"],
            "additionalProperties": false,
            "properties": {
              "key": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$",
                "description": "Unique view key used in navigation."
              },
              "label": {
                "type": "string",
                "description": "Display label for the view."
              },
              "icon": {
                "type": "string",
                "description": "Icon key for the activity bar / navigation."
              },
              "entrypoint": {
                "type": "string",
                "description": "Relative path to the Svelte component."
              }
            }
          }
        },

        "icons": {
          "type": "object",
          "description": "Icon registrations. Keys are icon names, values are import paths or component references.",
          "additionalProperties": {
            "type": "string"
          }
        },

        "statuses": {
          "type": "array",
          "description": "Custom statuses beyond the 12 canonical ones.",
          "items": {
            "type": "object",
            "required": ["key", "label", "icon"],
            "additionalProperties": false,
            "properties": {
              "key": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$"
              },
              "label": { "type": "string" },
              "icon": { "type": "string" },
              "color": {
                "type": "string",
                "enum": ["primary", "success", "warning", "destructive", "muted"],
                "description": "Semantic color for status rendering."
              },
              "spin": {
                "type": "boolean",
                "description": "Whether the status icon should animate."
              }
            }
          }
        },

        "relationshipTypes": {
          "type": "array",
          "description": "Relationship types this plugin introduces.",
          "items": {
            "type": "object",
            "required": ["forward", "inverse", "semantic"],
            "additionalProperties": false,
            "properties": {
              "forward": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$",
                "description": "Forward relationship name (e.g. 'delivers')."
              },
              "inverse": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]*$",
                "description": "Inverse relationship name (e.g. 'delivered-by')."
              },
              "semantic": {
                "type": "string",
                "description": "Human-readable description of the relationship."
              }
            }
          }
        },

        "hooks": {
          "type": "array",
          "description": "Lifecycle hooks this plugin listens to.",
          "items": {
            "type": "object",
            "required": ["event", "handler"],
            "additionalProperties": false,
            "properties": {
              "event": {
                "type": "string",
                "enum": [
                  "plugin:register",
                  "plugin:unregister",
                  "artifact:created",
                  "artifact:updated",
                  "artifact:deleted",
                  "artifact:status-changed",
                  "graph:refreshed",
                  "project:opened",
                  "project:closed"
                ],
                "description": "Lifecycle event to listen for."
              },
              "handler": {
                "type": "string",
                "description": "Relative path to the handler module."
              }
            }
          }
        }
      }
    },

    "entrypoints": {
      "type": "object",
      "description": "File paths for plugin initialisation and runtime loading.",
      "additionalProperties": false,
      "properties": {
        "register": {
          "type": "string",
          "description": "Module that exports a register() function called at plugin load time."
        },
        "views": {
          "type": "string",
          "description": "Barrel module exporting all view components."
        },
        "styles": {
          "type": "string",
          "description": "CSS file with plugin-specific styles."
        }
      }
    }
  }
}
