{
  "name": "@yourorg/plugin-name",
  "version": "0.1.0-dev",
  "displayName": "Your Sidecar Plugin",
  "description": "A sidecar plugin providing a long-running AI provider process.",
  "category": "custom",
  "provides": {
    "schemas": [],
    "views": [],
    "widgets": [],
    "relationships": [],
    "enforcement_mechanisms": [],
    "sidecar": {
      "key": "my-provider",
      "label": "My Provider",
      "runtime": "node",
      "entrypoint": "dist/sidecar.js",
      "requires": [{ "binary": "node", "minVersion": "20.0.0" }]
    }
  },
  "content": {
    "knowledge": {
      "source": "knowledge",
      "target": ".orqa/process/knowledge"
    }
  },
  "dependencies": {
    "npm": ["@orqastudio/types"],
    "system": [{ "binary": "node", "minVersion": "20.0.0" }]
  },
  "build": "npm run build",
  "lifecycle": {
    "install": "node scripts/post-install.mjs",
    "uninstall": "node scripts/pre-uninstall.mjs"
  }
}
