{
  "$id": "orqa://schemas/rule",
  "title": "Rule",
  "description": "Constraint that must be followed",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "layer", "scope"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "layer", "scope", "promoted-from"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^RULE-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["active", "inactive"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "layer": { "enum": ["core", "project", "plugin", "community", "user"] },
    "scope": { "enum": ["universal", "software", "governance"] },
    "promoted-from": {
      "type": ["array", "null"],
      "items": { "type": "string", "pattern": "^IMPL-\\d+$" }
    }
  },
  "bodyTemplate": {
    "description": "Semi-structured body for rule artifacts. Opening paragraph and Related Rules required; FORBIDDEN encouraged.",
    "sections": [
      { "heading": "FORBIDDEN", "required": false },
      { "heading": "Related Rules", "required": true }
    ],
    "notes": "Rules must start with an opening paragraph stating the rule. Domain-specific sections vary by rule."
  }
}
