{
  "$id": "orqa://schemas/lesson",
  "title": "Lesson",
  "description": "Learning capture from implementation",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "recurrence"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^IMPL-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["active", "recurring", "promoted"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "recurrence": { "type": "integer", "minimum": 0 },
    "promoted_to": { "type": ["string", "null"] }
  }
}
