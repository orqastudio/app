{
  "name": "planning-idea",
  "version": "0.1.0",
  "artifact_type": "planning-idea",
  "plugin": "@orqastudio/plugin-agile-planning",
  "description": "Planning idea lifecycle state machine. Planning ideas are scoped implementation approaches derived from discovery decisions. They represent concrete approaches to implementing a feature or capability, distinct from discovery-stage ideas which are high-level product concepts.\n",
  "initial_state": "draft",
  "states": {
    "draft": {
      "category": "planning",
      "description": "Planning idea has been drafted but not yet evaluated."
    },
    "evaluating": {
      "category": "planning",
      "description": "Planning idea is being evaluated — feasibility, effort, risks assessed.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Planning idea evaluation started"
          }
        }
      ]
    },
    "accepted": {
      "category": "active",
      "description": "Planning idea has been accepted for implementation.",
      "on_enter": [
        {
          "type": "set_field",
          "params": {
            "field": "accepted_at",
            "value": "${now}"
          }
        },
        {
          "type": "append_log",
          "params": {
            "message": "Planning idea accepted"
          }
        }
      ]
    },
    "hold": {
      "category": "active",
      "description": "Planning idea is paused, waiting for input or decisions."
    },
    "rejected": {
      "category": "terminal",
      "description": "Planning idea was evaluated and rejected — not viable or out of scope.",
      "on_enter": [
        {
          "type": "set_field",
          "params": {
            "field": "rejected_at",
            "value": "${now}"
          }
        },
        {
          "type": "append_log",
          "params": {
            "message": "Planning idea rejected"
          }
        }
      ]
    },
    "archived": {
      "category": "terminal",
      "description": "Planning idea is archived."
    }
  },
  "transitions": [
    {
      "from": "draft",
      "to": "evaluating",
      "event": "evaluate",
      "description": "Begin evaluating the planning idea."
    },
    {
      "from": "draft",
      "to": "accepted",
      "event": "accept",
      "description": "Fast-track directly to accepted."
    },
    {
      "from": "evaluating",
      "to": "accepted",
      "event": "accept",
      "description": "Accept the planning idea for implementation."
    },
    {
      "from": "evaluating",
      "to": "rejected",
      "event": "reject",
      "description": "Reject the planning idea."
    },
    {
      "from": "evaluating",
      "to": "hold",
      "event": "pause",
      "description": "Pause evaluation pending input."
    },
    {
      "from": "evaluating",
      "to": "draft",
      "event": "rework",
      "description": "Return to draft for revision."
    },
    {
      "from": "hold",
      "to": "evaluating",
      "event": "resume",
      "description": "Resume evaluation."
    },
    {
      "from": "hold",
      "to": "archived",
      "event": "archive",
      "description": "Archive from hold."
    },
    {
      "from": "accepted",
      "to": "archived",
      "event": "archive",
      "description": "Archive an accepted idea (superseded or no longer needed)."
    },
    {
      "from": "rejected",
      "to": "archived",
      "event": "archive"
    },
    {
      "from": [
        "draft",
        "hold"
      ],
      "to": "archived",
      "event": "archive",
      "description": "Archive from non-active states."
    }
  ],
  "migration": {
    "draft": "draft",
    "evaluating": "evaluating",
    "accepted": "accepted",
    "hold": "hold",
    "rejected": "rejected",
    "archived": "archived"
  },
  "_resolved_by": "orqa plugin install",
  "_skeleton": "@orqastudio/plugin-agile-planning (workflows/planning-idea.workflow.yaml)",
  "_resolved_at": "2026-03-30T10:47:00.852Z"
}