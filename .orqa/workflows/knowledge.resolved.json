{
  "name": "knowledge",
  "version": "0.1.0",
  "artifact_type": "knowledge",
  "plugin": "@orqastudio/plugin-core-framework",
  "description": "Knowledge lifecycle state machine. Knowledge artifacts capture domain expertise, thinking modes, and contextual information injected into agent prompts. The workflow tracks capture, exploration, active use, review, and completion.\n",
  "initial_state": "captured",
  "states": {
    "captured": {
      "category": "planning",
      "description": "Knowledge has been captured but not yet explored."
    },
    "exploring": {
      "category": "planning",
      "description": "Knowledge is being explored — scope, accuracy, relevance.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Knowledge exploration started"
          }
        }
      ]
    },
    "active": {
      "category": "active",
      "description": "Knowledge is actively being used in agent prompts.",
      "on_enter": [
        {
          "type": "set_field",
          "params": {
            "field": "activated_at",
            "value": "${now}"
          }
        },
        {
          "type": "append_log",
          "params": {
            "message": "Knowledge activated"
          }
        }
      ]
    },
    "hold": {
      "category": "active",
      "description": "Knowledge is paused — accuracy or relevance under question."
    },
    "review": {
      "category": "review",
      "description": "Knowledge is being reviewed for continued accuracy.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Knowledge entered review"
          }
        }
      ]
    },
    "completed": {
      "category": "completed",
      "description": "Knowledge lifecycle is complete — content has been fully documented.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Knowledge completed"
          }
        }
      ]
    },
    "surpassed": {
      "category": "terminal",
      "description": "Knowledge has been superseded by newer information."
    },
    "archived": {
      "category": "terminal",
      "description": "Knowledge is archived."
    }
  },
  "transitions": [
    {
      "from": "captured",
      "to": "exploring",
      "event": "explore",
      "description": "Begin exploring scope and accuracy."
    },
    {
      "from": "captured",
      "to": "active",
      "event": "activate",
      "description": "Fast-track to active use."
    },
    {
      "from": "exploring",
      "to": "active",
      "event": "activate",
      "description": "Begin active use in prompts."
    },
    {
      "from": "exploring",
      "to": "hold",
      "event": "pause",
      "description": "Pause exploration pending verification."
    },
    {
      "from": "active",
      "to": "review",
      "event": "submit_for_review",
      "description": "Trigger periodic accuracy review."
    },
    {
      "from": "active",
      "to": "hold",
      "event": "pause",
      "description": "Pause active use."
    },
    {
      "from": "active",
      "to": "archived",
      "event": "archive",
      "description": "Archive knowledge directly."
    },
    {
      "from": "hold",
      "to": "active",
      "event": "resume",
      "description": "Resume active use."
    },
    {
      "from": "hold",
      "to": "exploring",
      "event": "rescope",
      "description": "Return to exploration for re-scoping."
    },
    {
      "from": "review",
      "to": "active",
      "event": "reaffirm",
      "description": "Knowledge is still accurate — return to active."
    },
    {
      "from": "review",
      "to": "completed",
      "event": "retire",
      "description": "Knowledge is complete — no further updates needed."
    },
    {
      "from": "completed",
      "to": "surpassed",
      "event": "surpass"
    },
    {
      "from": "completed",
      "to": "archived",
      "event": "archive"
    },
    {
      "from": "surpassed",
      "to": "archived",
      "event": "archive"
    },
    {
      "from": [
        "captured",
        "exploring",
        "hold"
      ],
      "to": "archived",
      "event": "archive",
      "description": "Archive from non-active states."
    }
  ],
  "migration": {
    "captured": "captured",
    "exploring": "exploring",
    "active": "active",
    "hold": "hold",
    "review": "review",
    "completed": "completed",
    "surpassed": "surpassed",
    "archived": "archived"
  },
  "_resolved_by": "orqa plugin install",
  "_skeleton": "@orqastudio/plugin-core-framework (workflows/knowledge.workflow.yaml)",
  "_resolved_at": "2026-03-31T11:59:53.096Z"
}