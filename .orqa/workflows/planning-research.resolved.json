{
  "name": "planning-research",
  "version": "0.1.0",
  "artifact_type": "planning-research",
  "plugin": "@orqastudio/plugin-agile-planning",
  "description": "Planning research lifecycle state machine. Planning research artifacts are technical spikes and implementation feasibility analyses conducted during the planning stage. They investigate how to build something, distinct from discovery research which investigates what to build.\n",
  "initial_state": "proposed",
  "states": {
    "proposed": {
      "category": "planning",
      "description": "Research spike has been proposed but not yet started."
    },
    "investigating": {
      "category": "active",
      "description": "Research spike is actively being investigated.",
      "on_enter": [
        {
          "type": "set_field",
          "params": {
            "field": "started_at",
            "value": "${now}"
          }
        },
        {
          "type": "append_log",
          "params": {
            "message": "Planning research investigation started"
          }
        }
      ]
    },
    "hold": {
      "category": "active",
      "description": "Research is paused, waiting for resources or decisions."
    },
    "concluded": {
      "category": "completed",
      "description": "Research spike has concluded with findings.",
      "on_enter": [
        {
          "type": "set_field",
          "params": {
            "field": "concluded_at",
            "value": "${now}"
          }
        },
        {
          "type": "append_log",
          "params": {
            "message": "Planning research concluded"
          }
        }
      ]
    },
    "archived": {
      "category": "terminal",
      "description": "Research is archived."
    }
  },
  "transitions": [
    {
      "from": "proposed",
      "to": "investigating",
      "event": "start",
      "description": "Begin investigating the technical spike."
    },
    {
      "from": "investigating",
      "to": "concluded",
      "event": "conclude",
      "description": "Conclude investigation with findings."
    },
    {
      "from": "investigating",
      "to": "hold",
      "event": "pause",
      "description": "Pause investigation pending resources."
    },
    {
      "from": "hold",
      "to": "investigating",
      "event": "resume",
      "description": "Resume investigation."
    },
    {
      "from": "hold",
      "to": "archived",
      "event": "archive",
      "description": "Archive from hold."
    },
    {
      "from": "concluded",
      "to": "archived",
      "event": "archive"
    },
    {
      "from": [
        "proposed",
        "hold"
      ],
      "to": "archived",
      "event": "archive",
      "description": "Archive from non-active states."
    }
  ],
  "migration": {
    "proposed": "proposed",
    "investigating": "investigating",
    "hold": "hold",
    "concluded": "concluded",
    "archived": "archived"
  },
  "_resolved_by": "orqa plugin install",
  "_skeleton": "@orqastudio/plugin-agile-planning (workflows/planning-research.workflow.yaml)",
  "_resolved_at": "2026-03-31T16:47:16.518Z"
}