            "description": { "type": ["string", "null"] },
            "methodology": { "type": "string" },
            "relationships": { "type": "array", "items": { "type": "object", "required": ["target", "type"], "properties": { "target": { "type": "string" }, "type": { "type": "string" }, "rationale": { "type": "string" } } } }
          }
        },
        "additional_properties": true
      },
      "state_machine": {
        "name": "discovery-research",
        "version": "0.1.0",
        "artifact_type": "discovery-research",
        "plugin": "@orqastudio/plugin-agile-discovery",
        "description": "Discovery research lifecycle state machine. Research artifacts capture investigations, feasibility studies, and technical explorations during the discovery stage.",
        "initial_state": "captured",
        "states": {
          "captured": { "category": "planning", "description": "Research topic has been captured but not yet started." },
          "exploring": { "category": "planning", "description": "Research is being explored — defining scope, methodology, questions.", "on_enter": [{ "type": "append_log", "params": { "message": "Research exploration started" } }] },
          "active": { "category": "active", "description": "Research is actively being conducted.", "on_enter": [{ "type": "set_field", "params": { "field": "started_at", "value": "${now}" } }, { "type": "append_log", "params": { "message": "Research activated" } }] },
          "hold": { "category": "active", "description": "Research is paused, waiting for external input or resources." },
          "review": { "category": "review", "description": "Research findings are being reviewed.", "on_enter": [{ "type": "append_log", "params": { "message": "Research entered review" } }] },
          "completed": { "category": "completed", "description": "Research has been reviewed and findings accepted.", "on_enter": [{ "type": "set_field", "params": { "field": "completed_at", "value": "${now}" } }, { "type": "append_log", "params": { "message": "Research completed" } }] },
          "surpassed": { "category": "terminal", "description": "Research has been superseded by newer findings." },
          "archived": { "category": "terminal", "description": "Research is archived." }
        },
        "transitions": [
          { "from": "captured", "to": "exploring", "event": "explore", "description": "Begin defining research scope and methodology." },
          { "from": "captured", "to": "active", "event": "start", "description": "Fast-track directly to active research." },
          { "from": "exploring", "to": "active", "event": "start", "description": "Begin active research." },
          { "from": "exploring", "to": "hold", "event": "pause", "description": "Pause exploration pending resources." },
          { "from": "active", "to": "review", "event": "submit_for_review", "description": "Submit research findings for review." },
          { "from": "active", "to": "hold", "event": "pause", "description": "Pause research, waiting for input." },
          { "from": "hold", "to": "active", "event": "resume", "description": "Resume paused research." },
          { "from": "hold", "to": "exploring", "event": "rescope", "description": "Return to exploration for re-scoping." },
          { "from": "review", "to": "completed", "event": "approve", "description": "Research findings accepted." },
          { "from": "review", "to": "active", "event": "request_changes", "description": "Further research needed.", "actions": [{ "type": "append_log", "params": { "message": "Changes requested during research review" } }] },
          { "from": "completed", "to": "surpassed", "event": "surpass", "description": "Mark as superseded by newer research." },
          { "from": "completed", "to": "archived", "event": "archive" },
          { "from": "surpassed", "to": "archived", "event": "archive" },
          { "from": ["captured", "exploring", "hold"], "to": "archived", "event": "archive", "description": "Archive from any non-active state." }
        ],
        "migration": { "captured": "captured", "exploring": "exploring", "active": "active", "hold": "hold", "review": "review", "completed": "completed", "surpassed": "surpassed", "archived": "archived" }
      }
    },
    "discovery-decision": {
      "schema": {
        "id_prefix": "DISC-AD",
        "id_pattern": "^DISC-AD-[a-f0-9]{8}$",
        "default_path": ".orqa/discovery/decisions/",
        "icon": "scale",
        "source_plugin": "@orqastudio/plugin-agile-discovery",
        "fields": {
          "required": { "id": { "type": "string", "pattern": "^(AD|DISC-AD)-[a-f0-9]{8}$" } },
          "optional": {
            "title": { "type": "string" },
            "description": { "type": ["string", "null"] },
            "relationships": { "type": "array", "items": { "type": "object", "required": ["target", "type"], "properties": { "target": { "type": "string" }, "type": { "type": "string" }, "rationale": { "type": "string" } } } }
          }
        },
        "additional_properties": true
      },
      "state_machine": {
        "name": "discovery-decision",
        "version": "0.1.0",
        "artifact_type": "discovery-decision",
        "plugin": "@orqastudio/plugin-agile-discovery",
        "description": "Discovery decision lifecycle state machine. Discovery decisions capture high-level strategic choices made during the discovery stage — product direction, market positioning, technology bets.",
        "initial_state": "captured",
        "states": {
          "captured": { "category": "planning", "description": "Decision question has been captured but not yet explored." },
          "exploring": { "category": "planning", "description": "Decision space is being explored — options, trade-offs, constraints.", "on_enter": [{ "type": "append_log", "params": { "message": "Decision exploration started" } }] },
          "active": { "category": "active", "description": "Decision is actively being deliberated — a preferred option is being developed.", "on_enter": [{ "type": "set_field", "params": { "field": "started_at", "value": "${now}" } }, { "type": "append_log", "params": { "message": "Decision deliberation active" } }] },
          "hold": { "category": "active", "description": "Decision is paused, waiting for external input." },
          "review": { "category": "review", "description": "Decision is being reviewed for acceptance.", "on_enter": [{ "type": "append_log", "params": { "message": "Decision entered review" } }] },
