{
  "name": "pillar",
  "version": "0.1.0",
  "artifact_type": "pillar",
  "plugin": "@orqastudio/plugin-agile-discovery",
  "description": "Pillar lifecycle state machine. Pillars are foundational principles that uphold the vision. Like visions, they have a simple lifecycle — activated, reviewed, and eventually superseded or archived.\n",
  "initial_state": "active",
  "states": {
    "active": {
      "category": "active",
      "description": "Pillar is an active guiding principle.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Pillar activated"
          }
        }
      ]
    },
    "review": {
      "category": "review",
      "description": "Pillar is being reviewed for continued relevance.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Pillar entered review"
          }
        }
      ]
    },
    "surpassed": {
      "category": "terminal",
      "description": "Pillar has been superseded by a revised principle."
    },
    "archived": {
      "category": "terminal",
      "description": "Pillar is archived."
    }
  },
  "transitions": [
    {
      "from": "active",
      "to": "review",
      "event": "submit_for_review",
      "description": "Trigger periodic relevance review."
    },
    {
      "from": "active",
      "to": "archived",
      "event": "archive",
      "description": "Archive a pillar directly."
    },
    {
      "from": "review",
      "to": "active",
      "event": "reaffirm",
      "description": "Pillar is still relevant — return to active."
    },
    {
      "from": "review",
      "to": "surpassed",
      "event": "surpass",
      "description": "Pillar is no longer relevant — mark as superseded."
    },
    {
      "from": "surpassed",
      "to": "archived",
      "event": "archive"
    }
  ],
  "migration": {
    "active": "active",
    "review": "review",
    "surpassed": "surpassed",
    "archived": "archived"
  },
  "_resolved_by": "orqa plugin install",
  "_skeleton": "@orqastudio/plugin-agile-discovery (workflows/pillar.workflow.yaml)",
  "_resolved_at": "2026-04-04T08:19:03.610Z"
}