{
  "name": "persona",
  "version": "0.1.0",
  "artifact_type": "persona",
  "plugin": "@orqastudio/plugin-agile-discovery",
  "description": "Persona lifecycle state machine. Personas represent target users or stakeholders. They have a simple lifecycle — activated, reviewed periodically, and eventually superseded or archived.\n",
  "initial_state": "active",
  "states": {
    "active": {
      "category": "active",
      "description": "Persona is an active target user profile.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Persona activated"
          }
        }
      ]
    },
    "review": {
      "category": "review",
      "description": "Persona is being reviewed for continued relevance.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Persona entered review"
          }
        }
      ]
    },
    "surpassed": {
      "category": "terminal",
      "description": "Persona has been superseded by a revised profile."
    },
    "archived": {
      "category": "terminal",
      "description": "Persona is archived."
    }
  },
  "transitions": [
    {
      "from": "active",
      "to": "review",
      "event": "submit_for_review",
      "description": "Trigger periodic relevance review."
    },
    {
      "from": "active",
      "to": "archived",
      "event": "archive",
      "description": "Archive a persona directly."
    },
    {
      "from": "review",
      "to": "active",
      "event": "reaffirm",
      "description": "Persona is still relevant — return to active."
    },
    {
      "from": "review",
      "to": "surpassed",
      "event": "surpass",
      "description": "Persona is no longer relevant — mark as superseded."
    },
    {
      "from": "surpassed",
      "to": "archived",
      "event": "archive"
    }
  ],
  "migration": {
    "active": "active",
    "review": "review",
    "surpassed": "surpassed",
    "archived": "archived"
  },
  "_resolved_by": "orqa plugin install",
  "_skeleton": "@orqastudio/plugin-agile-discovery (workflows/persona.workflow.yaml)",
  "_resolved_at": "2026-03-31T16:47:16.516Z"
}