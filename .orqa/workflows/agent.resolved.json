{
  "name": "agent",
  "version": "0.1.0",
  "artifact_type": "agent",
  "plugin": "@orqastudio/plugin-core-framework",
  "description": "Agent lifecycle state machine. Agent artifacts define specialist agent configurations with preambles, capabilities, and knowledge references. The workflow tracks capture, exploration, active deployment, review, and completion.\n",
  "initial_state": "captured",
  "states": {
    "captured": {
      "category": "planning",
      "description": "Agent has been captured but not yet explored."
    },
    "exploring": {
      "category": "planning",
      "description": "Agent configuration is being explored — preamble, capabilities, knowledge.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Agent exploration started"
          }
        }
      ]
    },
    "active": {
      "category": "active",
      "description": "Agent is actively deployed and available for task delegation.",
      "on_enter": [
        {
          "type": "set_field",
          "params": {
            "field": "activated_at",
            "value": "${now}"
          }
        },
        {
          "type": "append_log",
          "params": {
            "message": "Agent activated"
          }
        }
      ]
    },
    "hold": {
      "category": "active",
      "description": "Agent is paused — configuration under review or updating."
    },
    "review": {
      "category": "review",
      "description": "Agent configuration is being reviewed.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Agent entered review"
          }
        }
      ]
    },
    "completed": {
      "category": "completed",
      "description": "Agent lifecycle is complete — no longer needed.",
      "on_enter": [
        {
          "type": "append_log",
          "params": {
            "message": "Agent retired"
          }
        }
      ]
    },
    "surpassed": {
      "category": "terminal",
      "description": "Agent has been superseded by a newer configuration."
    },
    "archived": {
      "category": "terminal",
      "description": "Agent is archived."
    }
  },
  "transitions": [
    {
      "from": "captured",
      "to": "exploring",
      "event": "explore",
      "description": "Begin exploring agent configuration."
    },
    {
      "from": "captured",
      "to": "active",
      "event": "activate",
      "description": "Fast-track to active deployment."
    },
    {
      "from": "exploring",
      "to": "active",
      "event": "activate",
      "description": "Deploy agent."
    },
    {
      "from": "exploring",
      "to": "hold",
      "event": "pause",
      "description": "Pause configuration pending input."
    },
    {
      "from": "active",
      "to": "review",
      "event": "submit_for_review",
      "description": "Trigger periodic configuration review."
    },
    {
      "from": "active",
      "to": "hold",
      "event": "pause",
      "description": "Pause deployment."
    },
    {
      "from": "active",
      "to": "archived",
      "event": "archive",
      "description": "Archive agent directly."
    },
    {
      "from": "hold",
      "to": "active",
      "event": "resume",
      "description": "Resume deployment."
    },
    {
      "from": "hold",
      "to": "exploring",
      "event": "rescope",
      "description": "Return to exploration for reconfiguration."
    },
    {
      "from": "review",
      "to": "active",
      "event": "reaffirm",
      "description": "Agent configuration is still valid — return to active."
    },
    {
      "from": "review",
      "to": "completed",
      "event": "retire",
      "description": "Agent is no longer needed — retire."
    },
    {
      "from": "completed",
      "to": "surpassed",
      "event": "surpass"
    },
    {
      "from": "completed",
      "to": "archived",
      "event": "archive"
    },
    {
      "from": "surpassed",
      "to": "archived",
      "event": "archive"
    },
    {
      "from": [
        "captured",
        "exploring",
        "hold"
      ],
      "to": "archived",
      "event": "archive",
      "description": "Archive from non-active states."
    }
  ],
  "migration": {
    "captured": "captured",
    "exploring": "exploring",
    "active": "active",
    "hold": "hold",
    "review": "review",
    "completed": "completed",
    "surpassed": "surpassed",
    "archived": "archived"
  },
  "_resolved_by": "orqa plugin install",
  "_skeleton": "@orqastudio/plugin-core-framework (workflows/agent.workflow.yaml)",
  "_resolved_at": "2026-03-30T10:47:00.852Z"
}