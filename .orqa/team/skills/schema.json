{
  "$id": "orqa://schemas/skill",
  "title": "Skill",
  "description": "Domain knowledge or methodology loaded into agents",
  "type": "object",
  "required": ["id", "title", "description", "status", "layer"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "layer", "scope", "file-patterns", "version",
    "user-invocable", "allowed-tools", "license", "metadata"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^SKILL-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["active", "inactive"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "layer": { "enum": ["core", "setup", "project", "plugin", "community", "user"] },
    "scope": {
      "type": "array",
      "items": { "type": "string", "pattern": "^AGENT-\\d+$" },
      "description": "Agent IDs that should use this skill"
    },
    "file-patterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Glob patterns for file paths that trigger auto-injection of this skill"
    },
    "version": { "type": "string" },
    "user-invocable": { "type": "boolean" },
    "allowed-tools": { "type": "string" },
    "license": { "type": "string" },
    "metadata": { "type": "object" }
  }
}
