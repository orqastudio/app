{
  "$id": "orqa://schemas/milestone",
  "title": "Milestone",
  "description": "Strategic goal with gate question",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "gate"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^MS-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["planning", "active", "complete"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "deadline": { "type": ["string", "null"], "format": "date" },
    "gate": { "type": "string" }
  },
  "bodyTemplate": {
    "description": "Required body sections for milestone artifacts",
    "sections": [
      { "heading": "Context", "required": true },
      { "heading": "Epics", "required": true },
      { "heading": "Completion Criteria", "required": false }
    ]
  }
}
