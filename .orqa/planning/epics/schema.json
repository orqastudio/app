{
  "$id": "orqa://schemas/epic",
  "title": "Epic",
  "description": "Trackable work unit within a milestone",
  "type": "object",
  "required": [
    "id", "title", "description", "status", "priority",
    "created", "updated", "milestone", "pillars", "scoring"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^EPIC-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["draft", "ready", "in-progress", "review", "done"] },
    "priority": { "enum": ["P1", "P2", "P3"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "deadline": { "type": ["string", "null"], "format": "date" },
    "milestone": { "type": "string", "pattern": "^MS-\\d+$" },
    "pillars": {
      "type": "array",
      "items": { "type": "string", "pattern": "^PILLAR-\\d+$" }
    },
    "depends-on": {
      "type": "array",
      "items": { "type": "string", "pattern": "^EPIC-\\d+$" }
    },
    "blocks": {
      "type": "array",
      "items": { "type": "string", "pattern": "^EPIC-\\d+$" }
    },
    "research-refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "docs-required": {
      "type": "array",
      "items": { "type": "string" }
    },
    "docs-produced": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scoring": {
      "type": "object",
      "required": ["score"],
      "properties": { "score": { "type": "number" } },
      "additionalProperties": { "type": "number" }
    }
  }
}
