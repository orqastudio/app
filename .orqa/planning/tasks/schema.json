{
  "$id": "orqa://schemas/task",
  "title": "Task",
  "description": "Individual implementation unit within an epic",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "epic",
    "description",
    "created",
    "updated"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TASK-\\d+$"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "enum": [
        "todo",
        "in-progress",
        "done"
      ]
    },
    "epic": {
      "type": "string",
      "pattern": "^EPIC-\\d+$"
    },
    "description": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "depends-on": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^TASK-\\d+$"
      }
    },
    "assignee": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
