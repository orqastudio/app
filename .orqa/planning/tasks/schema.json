{
  "$id": "orqa://schemas/task",
  "title": "Task",
  "description": "Individual implementation unit within an epic",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "epic"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "epic", "depends-on", "assignee", "skills",
    "scope", "acceptance"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^TASK-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["todo", "in-progress", "done"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "epic": { "type": "string", "pattern": "^EPIC-\\d+$" },
    "depends-on": {
      "type": "array",
      "items": { "type": "string", "pattern": "^TASK-\\d+$" }
    },
    "assignee": { "type": "string", "pattern": "^AGENT-\\d+$" },
    "skills": {
      "type": "array",
      "items": { "type": "string", "pattern": "^SKILL-\\d+$" }
    },
    "scope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for task artifacts",
    "sections": [
      { "heading": "What", "required": true },
      { "heading": "How", "required": true },
      { "heading": "Verification", "required": true }
    ]
  }
}
