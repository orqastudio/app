{
  "$id": "orqa://schemas/pillar",
  "title": "Pillar",
  "description": "Guiding principle that features are evaluated against",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "gate"],
  "additionalProperties": false,
  "propertyOrder": [
    "id", "title", "description", "status",
    "created", "updated",
    "gate"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^PILLAR-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["active", "inactive"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "gate": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Gate question(s) to evaluate whether work serves this pillar"
    }
  },
  "bodyTemplate": {
    "description": "Required body sections for pillar artifacts",
    "sections": [
      { "heading": "What This Pillar Means", "required": true },
      { "heading": "Examples of Work That Serves This Pillar", "required": true },
      { "heading": "Anti-Patterns", "required": true },
      { "heading": "Conflict Resolution", "required": true }
    ]
  }
}
