{
  "$id": "orqa://schemas/pillar",
  "title": "Pillar",
  "description": "Guiding principle that features are evaluated against",
  "type": "object",
  "required": ["id", "title", "description", "status", "created", "updated", "gate"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^PILLAR-\\d+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "status": { "enum": ["active", "inactive"] },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "gate": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    }
  }
}
