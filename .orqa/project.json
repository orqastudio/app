{
  "name": "OrqaStudio Dogfood Environment",
  "dogfood": true,
  "description": null,
  "default_model": "auto",
  "excluded_paths": [
    "node_modules",
    ".git",
    "target",
    "dist",
    "build"
  ],
  "stack": {
    "languages": [
      "javascript",
      "rust",
      "svelte",
      "typescript"
    ],
    "frameworks": [
      "cargo"
    ],
    "package_manager": "cargo",
    "has_claude_config": true,
    "has_design_tokens": false
  },
  "governance": {
    "lessons": 84,
    "decisions": 70,
    "rules": 59,
    "documentation": 131,
    "has_claude_config": true
  },
  "icon": null,
  "show_thinking": false,
  "custom_system_prompt": null,
  "artifactLinks": {
    "displayModes": {},
    "colors": {}
  },
  "statuses": [],
  "delivery": {
    "types": []
  },
  "relationships": [],
  "plugins": {
    "@orqastudio/claude-code-connector": {
      "path": "connectors\\claude-code",
      "enabled": true,
      "version": "0.1.0-dev",
      "installed": true
    },
    "@orqastudio/plugin-cli": {
      "path": "plugins\\knowledge\\cli",
      "enabled": true,
      "version": "0.1.4-dev",
      "installed": true
    },
    "@orqastudio/plugin-plugin-dev": {
      "path": "plugins\\knowledge\\plugin-dev",
      "enabled": true,
      "version": "0.1.4-dev",
      "installed": true
    },
    "@orqastudio/plugin-rust": {
      "path": "plugins\\knowledge\\rust",
      "enabled": true,
      "version": "0.1.4-dev",
      "installed": true
    },
    "@orqastudio/plugin-svelte": {
      "path": "plugins\\knowledge\\svelte",
      "enabled": true,
      "version": "0.1.4-dev",
      "installed": true
    },
    "@orqastudio/plugin-systems-thinking": {
      "path": "plugins\\knowledge\\systems-thinking",
      "enabled": true,
      "version": "0.1.4-dev",
      "installed": true
    },
    "@orqastudio/plugin-tauri": {
      "path": "plugins\\knowledge\\tauri",
      "enabled": true,
      "version": "0.1.4-dev",
      "installed": true
