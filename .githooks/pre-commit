#!/usr/bin/env bash
# Generated by @orqastudio/plugin-core-framework — do not edit manually.
# Re-generate with: orqa install
#
# Hook scope: `orqa enforce --staged` is invoked with the list of staged files.
# The enforce command dispatches each engine only when relevant file types are
# staged. For Rust (cargo) engines this means:
#   - If no *.rs files are staged → the clippy and rustfmt engines are skipped.
#   - If *.rs files are staged → cargo runs scoped to only the packages that own
#     those files (-p pkg ...), NOT --workspace. This prevents compilation of
#     Tauri crates (orqa-studio, orqa-devtools) which require a built frontend
#     directory (app/build/ or devtools/build/) that doesn't exist on fresh
#     checkouts or when only backend code is being committed.
#   - If a staged Tauri crate file is detected and its frontend dir is missing,
#     the hook fails with an actionable error pointing at `npm run build`.
set -u

if [ "${ORQA_SKIP_HOOKS:-}" = "1" ]; then
  echo "WARNING: ORQA_SKIP_HOOKS=1 — skipping all pre-commit checks"
  exit 0
fi

if ! command -v orqa &> /dev/null; then
  PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  if [ -f "$PROJECT_ROOT/cli/dist/cli.js" ]; then
    ORQA="node $PROJECT_ROOT/cli/dist/cli.js"
  else
    echo "WARNING: orqa CLI not available — skipping pre-commit checks"
    exit 0
  fi
else
  ORQA="orqa"
fi

echo "=== Pre-commit: Running enforcement checks ==="
$ORQA enforce --staged
exit $?
