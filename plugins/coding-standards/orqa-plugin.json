{
  "name": "@orqastudio/plugin-coding-standards",
  "version": "0.1.4-dev",
  "displayName": "Coding Standards",
  "description": "Unified coding standards enforcement — config generation from governance rules, quality checks via orqa check, and organisation-wide standards sync.",
  "category": "coding-standards",
  "provides": {
    "schemas": [],
    "enforcement_mechanisms": [
      {
        "key": "lint",
        "description": "Linter enforcement (delegates to language-specific linters)",
        "strength": 6
      }
    ],
    "views": [],
    "widgets": [],
    "relationships": [],
    "knowledge": [
      {
        "key": "6125ab55",
        "id": "KNOW-1c2d005d",
        "label": "Config Generation from Rules"
      },
      {
        "key": "ea517e13",
        "id": "KNOW-126aa140",
        "label": "Quality Check Runner"
      }
    ],
    "cliTools": [
      {
        "key": "check",
        "command": "orqa check",
        "description": "Run all configured quality checks"
      },
      {
        "key": "configure",
        "command": "orqa check configure",
        "description": "Generate tool config files from enforcement rules"
      }
    ],
    "hooks": [],
    "knowledge_declarations": [
      {
        "id": "quality-check-runner",
        "tier": "on-demand",
        "roles": [
          "implementer",
          "reviewer"
        ],
        "tags": [
          "quality",
          "checks",
          "orqa-check"
        ],
        "priority": "P2",
        "summary": "Quality check runner: orqa check discovers tools from installed plugins and runs them all. Returns unified summary of lint, type-check, test results.",
        "content_file": "../../.orqa/process/knowledge/KNOW-126aa140.md"
      },
      {
        "id": "config-generation-from-rules",
        "tier": "on-demand",
        "roles": [
          "implementer"
        ],
        "tags": [
          "config-generation",
          "eslint",
          "clippy",
          "enforcement"
        ],
        "priority": "P2",
        "summary": "Config generation from rules: generates tool configs (ESLint, clippy, rustfmt) from OrqaStudio enforcement rules. Rules define what; this generates the how.",
        "content_file": "../../.orqa/process/knowledge/KNOW-1c2d005d.md"
      }
    ]
  },
  "content": {
    "knowledge": {
      "source": "knowledge",
      "target": ".orqa/process/knowledge"
    },
    "rules": {
      "source": "rules",
      "target": ".orqa/process/rules"
    }
  },
  "dependencies": {
    "npm": [
      "@orqastudio/cli",
      "@orqastudio/types"
    ]
  },
  "build": "npm run build",
  "role": "enhancement:delivery"
}
