#!/usr/bin/env bash
# OrqaStudio Git Hooks Plugin — post-commit auto-push
#
# Pushes to the remote after every commit. Enforces RULE-f609242f which
# requires every commit to be pushed immediately.
#
# - Sets upstream on first push for new branches
# - Skips push during rebase, merge, cherry-pick, or revert
# - Warns on failure but does not block (post-commit cannot prevent the commit)

# Do not use set -e — a push failure must not crash the hook
set -uo pipefail

# ── Skip during automated git operations ────────────────────────────────────

# Rebase in progress
if [ -d "$(git rev-parse --git-dir)/rebase-merge" ] || \
   [ -d "$(git rev-parse --git-dir)/rebase-apply" ]; then
  exit 0
fi

# Merge in progress
if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
  exit 0
fi

# Cherry-pick in progress
if [ -f "$(git rev-parse --git-dir)/CHERRY_PICK_HEAD" ]; then
  exit 0
fi

# Revert in progress
if [ -f "$(git rev-parse --git-dir)/REVERT_HEAD" ]; then
  exit 0
fi

# ── Skip if no remote configured ────────────────────────────────────────────

if ! git remote get-url origin &>/dev/null; then
  exit 0
fi

# ── Push ────────────────────────────────────────────────────────────────────

BRANCH=$(git branch --show-current)

# Detached HEAD (e.g., during bisect) — skip
if [ -z "$BRANCH" ]; then
  exit 0
fi

# Check if upstream is set
if git rev-parse --abbrev-ref --symbolic-full-name "@{u}" &>/dev/null; then
  # Upstream exists — regular push
  if ! git push 2>&1; then
    echo ""
    echo "WARNING: post-commit push failed. Run 'git push' manually."
    echo ""
  fi
else
  # No upstream — set it
  if ! git push -u origin "$BRANCH" 2>&1; then
    echo ""
    echo "WARNING: post-commit push failed. Run 'git push -u origin $BRANCH' manually."
    echo ""
  fi
fi
