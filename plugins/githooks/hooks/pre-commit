#!/usr/bin/env bash
# OrqaStudio Git Hooks Plugin — pre-commit enforcement
#
# Thin wrapper around `orqa check`. The CLI's check command uses the
# shared validation engine (same checks as the LSP). This hook just
# calls it and exits non-zero if it fails.
#
# Install: git config core.hooksPath plugins/githooks/hooks
# Or: copy/symlink this file to .git/hooks/pre-commit

set -euo pipefail

# Find project root (walk up to find .orqa/)
find_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.orqa" ]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}

PROJECT_ROOT=$(find_root)

# Violation logging for stability tracking
# Appends to tmp/precommit-violations.jsonl so the stability tracker can
# detect whether demoted rules' domains still have active violations.
log_violation() {
  local vtype="$1"
  local domain="$2"
  local detail="$3"
  mkdir -p "$PROJECT_ROOT/tmp"
  local ts
  ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date +"%Y-%m-%dT%H:%M:%SZ")
  local staged_files
  staged_files=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | head -20 | tr '\n' ',' | sed 's/,$//')
  printf '{"timestamp":"%s","violation_type":"%s","domain":"%s","detail":"%s","files":"%s"}\n' \
    "$ts" "$vtype" "$domain" "$detail" "$staged_files" \
    >> "$PROJECT_ROOT/tmp/precommit-violations.jsonl"
}

# Check if orqa CLI is available
if ! command -v orqa &> /dev/null; then
  # Try node-based fallback
  if [ -f "$PROJECT_ROOT/libs/cli/dist/cli.js" ]; then
    ORQA="node $PROJECT_ROOT/libs/cli/dist/cli.js"
  else
    echo "WARNING: orqa CLI not available — skipping pre-commit checks"
    exit 0
  fi
else
  ORQA="orqa"
fi

# Detect which file types are staged
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
  echo "=== Pre-commit: No staged files, skipping ==="
  exit 0
fi

HAS_RUST=false
HAS_FRONTEND=false
HAS_ARTIFACTS=false

while IFS= read -r file; do
  case "$file" in
    *.rs|Cargo.toml|Cargo.lock) HAS_RUST=true ;;
    *.svelte|*.ts|*.js|*.css|*.html) HAS_FRONTEND=true ;;
    .orqa/*.md|plugins/*.md) HAS_ARTIFACTS=true ;;
  esac
done <<< "$STAGED_FILES"

FAILED=false

# Run only relevant checks based on staged file types.
# Tool names match plugin manifests (orqa-plugin.json provides.tools):
#   rust plugin:   clippy, rustfmt, cargo-test
#   svelte plugin: eslint, svelte-check, vitest

if [ "$HAS_RUST" = true ]; then
  echo "=== Pre-commit: Checking Rust (rustfmt + clippy) ==="
  $ORQA check rustfmt 2>&1 || { log_violation "rustfmt" "rust" "format check failed"; FAILED=true; }
  $ORQA check clippy 2>&1 || { log_violation "clippy" "rust" "clippy warnings"; FAILED=true; }
fi

if [ "$HAS_FRONTEND" = true ]; then
  echo "=== Pre-commit: Checking frontend (eslint on staged files) ==="
  # Run eslint ONLY on staged frontend files to avoid pre-existing errors
  # in unstaged parts of the codebase.
  STAGED_FE=$(echo "$STAGED_FILES" | grep -E '\.(svelte|ts|js)$' || true)
  if [ -n "$STAGED_FE" ]; then
    echo "$STAGED_FE" | xargs npx eslint --config app/eslint.config.js --no-error-on-unmatched-pattern --max-warnings 0 2>&1 || { log_violation "eslint" "frontend" "lint errors"; FAILED=true; }
  fi
fi

if [ "$HAS_ARTIFACTS" = true ]; then
  echo "=== Pre-commit: Validating artifacts (shared engine) ==="
  $ORQA check validate 2>&1 || { log_violation "validate" "artifacts" "validation engine found errors"; FAILED=true; }
fi

if [ "$FAILED" = true ]; then
  echo ""
  echo "BLOCKED: Pre-commit checks found errors. Fix them before committing."
  exit 1
fi

echo "=== Pre-commit: All checks passed ==="
