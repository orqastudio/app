          "epic"
        ],
        "to": [
          "lesson"
        ],
        "description": "Task or epic addresses a lesson or implementation finding",
        "semantic": "corrective"
      },
      {
        "key": "delivers",
        "inverse": "delivered-by",
        "label": "Delivers",
        "inverseLabel": "Delivered By",
        "from": [
          "task"
        ],
        "to": [
          "epic"
        ],
        "description": "Task delivers work to an epic",
        "semantic": "hierarchy",
        "constraints": {
          "required": true,
          "minCount": 1,
          "statusRules": [
            {
              "evaluate": "target",
              "condition": "all-targets-in",
              "statuses": [
                "completed"
              ],
              "proposedStatus": "review",
              "description": "Epic moves to review when all delivering tasks are completed"
            }
          ]
        }
      },
      {
        "key": "fulfils",
        "inverse": "fulfilled-by",
        "label": "Fulfils",
        "inverseLabel": "Fulfilled By",
        "from": [
          "epic"
        ],
        "to": [
          "milestone"
        ],
        "description": "Epic fulfils a milestone checkpoint",
        "semantic": "hierarchy",
        "constraints": {
          "statusRules": [
            {
              "evaluate": "target",
              "condition": "all-targets-in",
              "statuses": [
                "completed"
              ],
              "proposedStatus": "review",
              "description": "Milestone moves to review when all fulfilling epics are completed"
            }
          ]
        }
      },
      {
        "key": "depends-on",
        "inverse": "depended-on-by",
        "label": "Depends On",
        "inverseLabel": "Depended On By",
        "from": [
          "task",
          "epic"
        ],
        "to": [
          "task",
          "epic"
        ],
        "description": "Task or epic cannot proceed until dependency is completed",
        "semantic": "dependency",
        "constraints": {
          "statusRules": [
            {
              "evaluate": "source",
              "condition": "any-target-in",
              "statuses": [
                "captured",
                "exploring",
                "ready",
                "prioritised",
                "active",
                "hold"
              ],
              "proposedStatus": "blocked",
              "description": "Task is blocked when any dependency is not yet completed"
            },
            {
              "evaluate": "source",
              "condition": "all-targets-in",
              "statuses": [
                "completed",
                "surpassed",
                "archived"
              ],
              "proposedStatus": "ready",
              "description": "Task is unblocked when all dependencies are completed"
            }
          ]
        }
      },
      {
        "key": "reports",
        "inverse": "reported-by",
        "label": "Reports",
        "inverseLabel": "Reported By",
        "from": [
