  "category": "tooling",
  "extends": [
    "@orqastudio/plugin-typescript"
  ],
  "requires": [
    "@orqastudio/plugin-typescript"
  ],
  "configExtensions": {
    "tsconfig": {
      "compilerOptions": {
        "verbatimModuleSyntax": true
      }
