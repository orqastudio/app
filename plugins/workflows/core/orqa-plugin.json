{
	"name": "@orqastudio/plugin-core-framework",
	"version": "0.1.4-dev",
	"displayName": "Core Framework",
	"description": "The agent execution model — universal roles, delegation, session management, knowledge loading, thinking mode classification. Every project gets this.",
	"categories": ["workflow", "infrastructure", "enforcement-generator"],
	"purpose": ["workflow", "infrastructure"],
	"stage_slot": "learning",
	"role": "core:framework",
	"uninstallable": true,
	"enforcement": [
		{
			"role": "generator",
			"engine": "prettier",
			"config_output": ".orqa/configs/.prettierrc",
			"generator": "scripts/generate-prettier-config.ts",
			"actions": {
				"check": {
					"command": "prettier",
					"args": ["--config", ".orqa/configs/.prettierrc", "--check"],
					"files": "*.{ts,svelte,js,json,css}"
				},
				"fix": {
					"command": "prettier",
					"args": ["--config", ".orqa/configs/.prettierrc", "--write"],
					"files": "*.{ts,svelte,js,json,css}"
				}
			},
			"watch": {
				"paths": [".orqa/learning/rules/**/*.md"],
				"filter": "engine: prettier",
				"on_change": "regenerate"
			},
			"file_types": ["*.ts", "*.svelte", "*.js", "*.json", "*.css"],
			"rules_path": "rules/prettier/"
		},
		{
			"role": "generator",
			"engine": "markdownlint",
			"config_output": ".orqa/configs/.markdownlint.json",
			"generator": "scripts/generate-markdownlint-config.ts",
			"actions": {
				"check": {
					"command": "markdownlint-cli2",
					"args": ["--config", ".orqa/configs/.markdownlint.json"],
					"files": "*.md"
				}
			},
			"watch": {
				"paths": [".orqa/learning/rules/**/*.md"],
				"filter": "engine: markdownlint",
				"on_change": "regenerate"
			},
			"file_types": ["*.md"],
			"rules_path": "rules/markdownlint/"
		}
	],
	"content": {
		"agents": {
			"source": "agents",
			"target": ".claude/agents"
		},
		"knowledge": {
			"source": "knowledge",
			"target": ".orqa/documentation/knowledge"
		},
		"rules": {
			"source": "rules",
			"target": ".orqa/learning/rules"
		},
		"docs": {
			"source": "docs",
			"target": ".orqa/documentation"
		},
		"workflows": {
			"source": "workflows",
			"target": ".orqa/workflows"
		}
	},
	"provides": {
		"schemas": [
			{
				"key": "decision",
				"label": "Decision",
				"plural": "Decisions",
				"icon": "scale",
				"defaultPath": ".orqa/learning/decisions",
				"idPrefix": "AD",
				"semantic": "governance",
				"reviewAction": "Review decision",
				"frontmatter": {
					"type": "object",
					"required": ["id", "status"],
					"properties": {
						"id": {
							"type": "string",
							"pattern": "^AD-[a-f0-9]{8}$"
						},
						"title": {
							"type": "string"
						},
						"description": {
							"type": ["string", "null"]
						},
						"relationships": {
							"type": "array",
							"items": {
								"type": "object",
								"required": ["target", "type"],
								"properties": {
									"target": {
										"type": "string"
									},
									"type": {
										"type": "string"
									},
									"rationale": {
										"type": "string"
									}
								}
							}
						}
					},
					"additionalProperties": true
				},
				"influence": "high"
			},
			{
				"key": "rule",
				"label": "Rule",
				"plural": "Rules",
				"icon": "shield",
				"defaultPath": ".orqa/learning/rules",
				"idPrefix": "RULE",
				"semantic": "governance",
				"reviewAction": "Review rule",
				"frontmatter": {
					"type": "object",
					"required": ["id", "status", "enforcement"],
					"properties": {
						"id": {
							"type": "string",
							"pattern": "^RULE-[a-f0-9]{8}$"
						},
						"title": {
							"type": "string"
						},
						"description": {
							"type": ["string", "null"]
						},
						"enforcement": {
							"type": "array"
						},
						"demoted_date": {
							"type": "string",
							"format": "date",
							"description": "ISO date when the rule was demoted to inactive"
						},
						"demoted_reason": {
							"type": "string",
							"description": "Why the rule was demoted (e.g. enforced by orqa lsp schema validation)"
						},
						"replaced_by": {
							"type": "string",
							"description": "What now covers this rule (e.g. orqa lsp, pre-commit hook)"
						},
						"stability_threshold": {
							"type": "number",
							"minimum": 1,
							"default": 10,
							"description": "Sessions with zero violations before the rule is safe to delete"
						},
						"stability_count": {
							"type": "number",
							"minimum": 0,
							"default": 0,
							"description": "Current count of consecutive clean sessions since demotion"
						},
						"relationships": {
							"type": "array",
							"items": {
								"type": "object",
								"required": ["target", "type"],
								"properties": {
									"target": {
										"type": "string"
									},
									"type": {
										"type": "string"
									},
									"rationale": {
										"type": "string"
									}
								}
							}
						}
					},
					"additionalProperties": true
				},
				"influence": "high"
