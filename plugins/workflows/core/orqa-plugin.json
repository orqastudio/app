				"prompt_template": "You coordinate multi-agent teams. Delegate all implementation. Read findings files. Never implement directly."
			},
			{
				"role": "implementer",
				"description": "Implements code changes",
				"prompt_template": "You implement code changes. Read requirements, write code, run tests. Follow architecture docs."
			},
			{
				"role": "reviewer",
				"description": "Reviews work against acceptance criteria",
				"prompt_template": "You review completed work. Check every AC with evidence. Produce PASS/FAIL verdicts."
			},
			{
				"role": "writer",
				"description": "Creates and edits documentation",
				"prompt_template": "You write documentation. Match target architecture, not current patterns."
			},
