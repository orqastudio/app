{
  "name": "@orqastudio/plugin-svelte",
  "version": "0.1.4-dev",
  "private": true,
  "type": "module",
  "description": "Svelte development infrastructure — extends TypeScript plugin with Svelte parser, svelte-check, Vitest config, and ESLint rules.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./eslint": {
      "import": "./dist/eslint/index.js"
    },
    "./test": {
      "import": "./dist/test/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@orqastudio/types": "0.1.4-dev",
    "@orqastudio/plugin-typescript": "0.1.4-dev",
    "svelte-language-server": "^0.17.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "svelte-check": ">=4.0.0",
    "vitest": ">=3.0.0",
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "vite": "^6.0.0",
    "typescript": "^5.9.0"
  }
}
