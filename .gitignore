node_modules/
dist/
build/
target/
models/
.svelte-kit/
.claude/
!targets/**/.claude/
.state/

# Plugin-generated content — regenerated by `orqa install` and daemon
# enforcement generators. Source of truth is the plugin, not these outputs.
.orqa/configs/
.orqa/schema.composed.json

# Root configs generated by enforcement plugins. Each tool reads from root
# because it lacks a --config flag or because other configs extend it.
# Source of truth: the generator script in the owning plugin.
clippy.toml
.rustfmt.toml
tsconfig.json
tsconfig.base.json
.prettierignore
*.swp
*.swo
.DS_Store
*.duckdb
*.duckdb.wal
connectors/claude-code/tsconfig.tsbuildinfo

# tsc / Svelte preprocessor output alongside source files.
# All packages use outDir: "dist" — any .js/.d.ts in src/ is orphaned build output.
libs/*/src/**/*.js
libs/*/src/**/*.d.ts
libs/*/src/**/*.js.map
libs/*/src/**/*.d.ts.map
cli/src/**/*.js
cli/src/**/*.d.ts
cli/src/**/*.js.map
cli/src/**/*.d.ts.map
plugins/**/src/**/*.js
plugins/**/src/**/*.d.ts
plugins/shared/**/*.js
plugins/shared/**/*.d.ts
sidecars/*/src/**/*.js
sidecars/*/src/**/*.d.ts
