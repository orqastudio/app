node_modules/
dist/
build/
target/
models/
.svelte-kit/
.claude/
!targets/**/.claude/
.state/
tests/fixtures/**/.state/

# Session-generated auto-memory directories
.auto-memory/

# Plugin-generated content — regenerated by `orqa install` and daemon
# enforcement generators. Source of truth is the plugin, not these outputs.
.orqa/configs/*
!.orqa/configs/.markdownlint.json
# .orqa/schema.composed.json — tracked during migration as target state reference

# Root configs generated by enforcement plugins. Tracked during Phase 1 Step 2
# migration (plugin generation pipeline not yet operational). Will be
# re-gitignored after `orqa install` generation is validated in Phase 3.
# Source of truth for each: the generator script in the owning plugin.
*.swp
*.swo
.DS_Store
*.duckdb
*.duckdb.wal
connectors/claude-code/tsconfig.tsbuildinfo

# tsc / Svelte preprocessor output alongside source files.
# All packages use outDir: "dist" — any .js/.d.ts in src/ is orphaned build output.
libs/*/src/**/*.js
libs/*/src/**/*.d.ts
libs/*/src/**/*.js.map
libs/*/src/**/*.d.ts.map
cli/src/**/*.js
cli/src/**/*.d.ts
cli/src/**/*.js.map
cli/src/**/*.d.ts.map
plugins/**/src/**/*.js
plugins/**/src/**/*.d.ts
plugins/shared/**/*.js
plugins/shared/**/*.d.ts
sidecars/*/src/**/*.js
sidecars/*/src/**/*.d.ts
